print(1+3)
quit()
q(0)
q()
install.packages("ggplot2")
library(ggplot2)
# 建立資料框
data <- data.frame(
年份 = c(2012, 2013, 2014, 2015, 2016, 2017, 2018, 2019),
男性人口 = c(100, 120, 130, 125, 140, 150, 155, 160),
女性人口 = c(110, 115, 125, 130, 135, 145, 150, 155),
未婚率 = c(20, 22, 25, 24, 23, 21, 19, 18)
)
# 製作長條圖
bar_plot <- ggplot(data, aes(年份)) +
geom_bar(aes(y = 男性人口, fill = "男性人口"), stat = "identity", width = 0.4) +
geom_bar(aes(y = 女性人口, fill = "女性人口"), stat = "identity", width = 0.4) +
scale_fill_manual(values = c("男性人口" = "blue", "女性人口" = "pink")) +
labs(x = "年份", y = "人口數", fill = "性別") +
ggtitle("男性人口和女性人口") +
theme_minimal()
# 製作折線圖
line_plot <- ggplot(data, aes(年份, 未婚率)) +
geom_line(color = "red") +
labs(x = "年份", y = "未婚率") +
ggtitle("未婚率") +
theme_minimal()
# 合併圖表
combined_plot <- plot_grid(bar_plot, line_plot, ncol = 1, align = "v")
