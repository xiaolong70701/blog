# 載入必要套件
library(ggplot2)
# 建立資料框架
year <- c(2012, 2013, 2014, 2015, 2016, 2017, 2018, 2019)
male_pop <- c(100, 120, 110, 130, 140, 160, 150, 170)
female_pop <- c(110, 100, 130, 120, 150, 140, 170, 160)
unmarried_rate <- c(0.2, 0.3, 0.25, 0.35, 0.4, 0.35, 0.45, 0.5)
data <- data.frame(year, male_pop, female_pop, unmarried_rate)
# 製作長條圖和折線圖
ggplot(data) +
geom_col(aes(x = year - 0.15, y = male_pop, fill = "Male"), width = 0.3) +
geom_col(aes(x = year + 0.15, y = female_pop, fill = "Female"), width = 0.3) +
geom_line(aes(x = year, y = unmarried_rate * max(male_pop), group = 1, color = "Unmarried Rate"), size = 1) +
geom_point(aes(x = year, y = unmarried_rate * max(male_pop), color = "Unmarried Rate"), size = 3) +
scale_fill_manual(values = c("Male" = "blue", "Female" = "pink")) +
scale_color_manual(values = c("Unmarried Rate" = "green")) +
labs(x = "年份", y = "人口數 / 未婚率", fill = "性別", color = "未婚率") +
ggtitle("人口數和未婚率的變化") +
theme_minimal()
