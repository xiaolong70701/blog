ggplot(data) +
geom_col(aes(x = year - 0.15, y = male_pop, fill = "Male"), width = 0.3) +
geom_col(aes(x = year + 0.15, y = female_pop, fill = "Female"), width = 0.3) +
geom_line(aes(x = year, y = unmarried_rate * max(male_pop), group = 1, color = "Unmarried Rate"), lwd = 1) +
geom_point(aes(x = year, y = unmarried_rate * max(male_pop), color = "Unmarried Rate"), lwd = 3) +
scale_fill_manual(values = c("Male" = "blue", "Female" = "pink")) +
