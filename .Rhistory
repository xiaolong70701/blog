# 绘制标准正态分布
x <- seq(-4, 4, length.out = 100)  # 生成x轴数据
y1 <- dnorm(x)  # 标准正态分布的概率密度函数
plot(x, y1, type = "l", xlab = "x", ylab = "Density", main = "Standard Normal Distribution")
# 在同一图上叠加 1/x^2
x2 <- seq(0, 4, length.out = 100)  # 生成x轴数据
y2 <- 1/(x2^2)  # 1/x^2函数
lines(x2, y2, col = "red")
# 添加图例
legend("topright", legend = c("Standard Normal Distribution", "1/x^2"), col = c("black", "red"), lty = 1)
