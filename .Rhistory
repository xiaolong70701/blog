data <- data.frame(year, male_pop, female_pop, unmarried_rate)
# 製作長條圖和折線圖
ggplot(data) +
geom_col(aes(x = year - 0.15, y = male_pop, fill = "Male"), width = 0.3) +
geom_col(aes(x = year + 0.15, y = female_pop, fill = "Female"), width = 0.3) +
geom_line(aes(x = year, y = unmarried_rate * max(male_pop), group = 1, color = "Unmarried Rate"), linewidth = 1) +
geom_point(aes(x = year, y = unmarried_rate * max(male_pop), color = "Unmarried Rate"), linewidth = 3) +
scale_fill_manual(values = c("Male" = "blue", "Female" = "pink")) +
scale_color_manual(values = c("Unmarried Rate" = "green")) +
labs(x = "年份", y = "人口數 / 未婚率", fill = "性別", color = "未婚率") +
ggtitle("人口數和未婚率的變化") +
theme_minimal()
# 製作長條圖和折線圖
ggplot(data) +
geom_col(aes(x = year - 0.15, y = male_pop, fill = "Male"), width = 0.3) +
geom_col(aes(x = year + 0.15, y = female_pop, fill = "Female"), width = 0.3) +
geom_line(aes(x = year, y = unmarried_rate * max(male_pop), group = 1, color = "Unmarried Rate"), lwd = 1) +
geom_point(aes(x = year, y = unmarried_rate * max(male_pop), color = "Unmarried Rate"), lwd = 3) +
scale_fill_manual(values = c("Male" = "blue", "Female" = "pink")) +
