install.packages("VennDiagram")
# 載入套件
library(VennDiagram)
# 定義集合的名稱和元素
set1 <- c("A", "B", "C", "D")
set2 <- c("B", "C", "E", "F")
set3 <- c("C", "D", "E", "G")
# 繪製文氏圖
venn.diagram(
x = list(set1 = set1, set2 = set2, set3 = set3),
filename = NULL,
output = TRUE,
imagetype = "png",
category.names = c("Set 1", "Set 2", "Set 3"),
fill = c("red", "blue", "green"),
alpha = 0.5,
cat.col = c("red", "blue", "green"),
cat.cex = 1.5,
cat.fontface = "bold",
cat.default.pos = "outer",
cat.pos = 0,
cat.dist = 0.08,
cat.fontfamily = "sans",
cat.just = list(c(0.5, 0.5), c(0.5, 0.5), c(0.5, 0.5)),
cat.fontcolor = c("white", "white", "white"),
cat.cex = 1.2,
cex = 1.5,
fontfamily = "sans",
main = "Intersection Venn Diagram",
main.fontfamily = "sans",
main.cex = 1.8,
col = "transparent",
lwd = 2,
fill.alpha = 0.5,
label.col = c("white", "white", "white"),
euler.d = TRUE,
euler.pos = c(0.3, 0.15)
)
