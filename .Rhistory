# 載入必要套件
library(ggplot2)
library(showtext)
data <- read.csv("./gender.csv")
getwd()
wd <- "/Users/anthonysung/Library/Mobile Documents/com~apple~CloudDocs/data/NTU course data/111/111-2/統計學習理論簡介/report/mate choice/"
setwd(wd)
library(dplyr)
group <- read.csv("./psfd2020.csv") %>%
mutate(gender = ifelse(a01 == 1, 1, 0),
age = 112 - a02a,
edu = ifelse(a03a %in% 1:11, 0, ifelse(a03a %in% 12:15, 1, NA)),
income = ifelse(w06a %in% 1:3000000, w06a, NA),
marriage = ifelse(w21c %in% c(1, 2), ifelse(w21c == 2, 0, 1), NA),
mate01 = ifelse(w21b01 %in% c(1, 2), w21b01, NA),
mate02 = ifelse(w21b02 %in% c(1, 2), w21b02, NA),
mate03 = ifelse(w21b03 %in% c(1, 2), w21b03, NA),
mate04 = ifelse(w21b04 %in% c(1, 2), w21b04, NA),
mate05 = ifelse(w21b05 %in% c(1, 2), w21b05, NA),
mate06 = ifelse(w21b06 %in% c(1, 2), w21b06, NA),
mate07 = ifelse(w21b07 %in% c(1, 2), w21b07, NA),
mate08 = ifelse(w21b08 %in% c(1, 2), w21b08, NA),
mate09 = ifelse(w21b09 %in% c(1, 2), w21b09, NA),
mate10 = ifelse(w21b10 %in% c(1, 2), w21b10, NA)) %>%
na.omit() %>%
select(gender, age, edu, marriage, income, starts_with("mate")) %>%
mutate(across(starts_with("mate"), ~ifelse(. == 2, 0, .))) %>%
mutate(active = rowSums(select(., starts_with("mate")))) %>%
select(-starts_with("mate")) %>%
mutate(active = ifelse(active >= 5, 1, 0))
x <- group[, c("gender", "age", "edu", "marriage", "income")] %>% as.matrix()
y <- group$active
# fit <- cv.glmnet(x, y, family = "binomial")
# print(fit$lambda)  # 正則化參數的值
# print(fit$nzero)   # 非零係數的變量數量
# print(coef(fit, s = "lambda.min"))  # 正則化參數的最小值下的係數估計
model <- glm(y ~ x, family = "binomial")
summary(model)
View(group)
