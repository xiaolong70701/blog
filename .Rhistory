x = dnorm(1000)
plot(x)
x = rnorm(1000)
y = dnorm(x)
plot(x, y, type = "l")
x <- seq(-4, 4, length=1000)
y = dnorm(x)
plot(x, y, type = "l")
x <- seq(-4, 4, length=1000)
y = dnorm(x)
plot(x, y, type = "l", color = "deepskyblue3")
x <- seq(-4, 4, length=1000)
y = dnorm(x)
plot(x, y, type = "l", col = "deepskyblue3")
