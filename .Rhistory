relative_frequencies[i] <- simulate_coin_toss(i)
}
# 繪製相對頻率的折線圖
data <- data.frame(N = 1:num_tosses, Relative_Frequency = relative_frequencies)
ggplot(data, aes(x = N, y = Relative_Frequency)) +
geom_line(color = "black") +
geom_hline(yintercept = 0.5, color = "#2596be") +
labs(x = "Number of tosses",
y = "Relative frequencies")
library(ggplot2)
# 定義模擬硬幣投擲的函數
simulate_coin_toss <- function(N) {
tosses <- sample(c("Head", "Tail"), N, replace = TRUE)
num_heads <- sum(tosses == "Head")
relative_frequency <- num_heads / N
return(relative_frequency)
}
# 執行模擬
num_tosses <- 1000  # 指定投擲硬幣的次數N
relative_frequencies <- numeric(num_tosses)
for (i in 1:num_tosses) {
relative_frequencies[i] <- simulate_coin_toss(i)
}
# 繪製相對頻率的折線圖
data <- data.frame(N = 1:num_tosses, Relative_Frequency = relative_frequencies)
ggplot(data, aes(x = N, y = Relative_Frequency)) +
geom_line(color = "black") +
geom_hline(yintercept = 0.5, color = "#Ce0e4e") +
labs(x = "Number of tosses",
y = "Relative frequencies")
# Sample sets A1, A2, and A3
A1 <- c(1, 2, 3, 4)
A2 <- c(3, 4, 5, 6)
A3 <- c(7, 8, 9, 10)
# Calculate the intersection of all sets A1, A2, and A3
A <- intersect(intersect(A1, A2), A3)
# Calculate the intersection of A and Ai for i = 1, 2, 3
A_intersects_A1 <- intersect(A, A1)
A_intersects_A2 <- intersect(A, A2)
A_intersects_A3 <- intersect(A, A3)
# Check if A∩Ai and A∩Aj are disjoint for all i ≠ j
disjoint_A1_A2 <- length(intersect(A_intersects_A1, A_intersects_A2)) == 0
disjoint_A1_A3 <- length(intersect(A_intersects_A1, A_intersects_A3)) == 0
disjoint_A2_A3 <- length(intersect(A_intersects_A2, A_intersects_A3)) == 0
# Output the results
cat("A ∩ A1:", A_intersects_A1, "\n")
cat("A ∩ A2:", A_intersects_A2, "\n")
cat("A ∩ A3:", A_intersects_A3, "\n")
cat("A ∩ A1 and A ∩ A2 are disjoint:", disjoint_A1_A2, "\n")
cat("A ∩ A1 and A ∩ A3 are disjoint:", disjoint_A1_A3, "\n")
cat("A ∩ A2 and A ∩ A3 are disjoint:", disjoint_A2_A3, "\n")
# Load the required library
library(VennDiagram)
# Define the sets Ai for i = 1, 2, 3
Ai_1 <- c(1, 2, 3, 4, 5)
Ai_2 <- c(3, 4, 5, 6, 7)
Ai_3 <- c(5, 6, 7, 8, 9)
# Create the Venn diagram
venn.diagram(
x = list(A = Ai_1, B = Ai_2, C = Ai_3),
category.names = c("A", "B", "C"),
filename = NULL,
output = TRUE,
imagetype = "png",
col = "transparent",
fill = c("cornflowerblue", "green", "yellow"),
alpha = 0.5,
label.col = c("white", "white", "white"),
cex = 2.5,
fontfamily = "serif",
cat.cex = 2.5,
cat.fontfamily = "serif",
cat.col = c("black", "black", "black"),
cat.dist = c(0.03, 0.03, 0.03),
cat.pos = c(0, 0, 0),
cat.default.pos = "text",
cat.fontface = "bold",
cat.fontfamily = "serif"
)
