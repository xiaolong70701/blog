# Load the ggplot2 package
library(ggplot2)
# Event probabilities (make sure they add up to 1)
prob_event_A <- 0.6
prob_event_B <- 0.4
# Create a data frame for the events and probabilities
events_data <- data.frame(
Event = c("Event A", "Event B"),
Probability = c(prob_event_A, prob_event_B)
)
# Create the bar plot
ggplot(events_data, aes(x = "", y = Probability, fill = Event)) +
geom_bar(stat = "identity", width = 0.5) +
coord_polar(theta = "y") +
labs(title = "Mutually Exclusive Events",
x = NULL,
y = "Probability",
fill = "Event") +
theme_minimal()
