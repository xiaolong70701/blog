# 安裝和載入所需套件
library(ggplot2)
# 建立家戶數據
households <- c(1, 2, 3, 4, 5)
income <- c(10, 15, 20, 25, 30)
# 計算每個家戶的累積收入和總收入
cumulative_income <- cumsum(income)
total_income <- sum(income)
# 計算 Lorenz curve 上每個點的 x 和 y 座標
x <- c(0, seq_along(cumulative_income) / length(cumulative_income), 1)
y <- c(0, cumulative_income / total_income, 1)
# 繪製 Lorenz curve
df <- data.frame(x = x, y = y)
ggplot(df, aes(x, y)) +
geom_line() +
geom_segment(aes(x = x, xend = x, y = 0, yend = y), linetype = "dashed") +
geom_segment(aes(x = 0, xend = x, y = y, yend = y), linetype = "dashed") +
xlim(0, 1) +
ylim(0, 1) +
labs(title = "Lorenz Curve",
x = "Cumulative Share of Households",
y = "Cumulative Share of Income")
# Install and load the required package
library(ggplot2)
# Define the functions F(x) and G(x)
F <- function(x) {
ifelse(x >= 0, 1 - exp(-x), 0)
}
G <- function(x) {
ifelse(x >= 0, 1 - exp(-2 * x), 0)
}
# Create a sequence of x values
x <- seq(-5, 5, by = 0.1)
# Compute the corresponding y values using the functions F(x) and G(x)
y_F <- F(x)
y_G <- G(x)
# Create a data frame to hold the x and y values
df <- data.frame(x = x, F = y_F, G = y_G)
# Plot the functions F(x) and G(x)
ggplot(df, aes(x)) +
geom_line(aes(y = F), color = "blue", linetype = "solid", size = 1, label = "F(x)") +
geom_line(aes(y = G), color = "red", linetype = "dashed", size = 1, label = "G(x)") +
labs(title = "Plot of F(x) and G(x)",
x = "x",
y = "Function value") +
theme_minimal()
library(ggplot2)
# Define the functions F(x) and G(x)
F <- function(x) {
ifelse(x >= 0, 1 - exp(-x), 0)
}
G <- function(x) {
ifelse(x >= 0, 1 - exp(-2 * x), 0)
}
# Create a sequence of x values for the portion where x >= 0
x_positive <- seq(0, 5, by = 0.1)
# Compute the corresponding y values using the functions F(x) and G(x) for the portion where x >= 0
y_F_positive <- F(x_positive)
y_G_positive <- G(x_positive)
# Create a data frame to hold the x and y values
df_F <- data.frame(x = x_positive, F = y_F_positive)
df_G <- data.frame(x = x_positive, G = y_G_positive)
# Plot the functions F(x) and G(x) where x >= 0 and y > 0
ggplot() +
geom_line(data = df_F, aes(x, F), color = "blue", linetype = "solid", size = 1, label = "F(x)") +
geom_line(data = df_G, aes(x, G), color = "red", linetype = "dashed", size = 1, label = "G(x)") +
labs(title = "Plot of F(x) and G(x) where x >= 0 and y > 0",
x = "x",
y = "Function value") +
theme_minimal()
