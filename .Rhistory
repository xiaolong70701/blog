# 安裝和加載所需的包
install.packages("ggplot2")
library(ggplot2)
# 設定隨機漫步的步數
num_steps <- 100
# 創建隨機漫步的數據
set.seed(123)  # 設置種子以確保可再現性
steps <- sample(c(-1, 1), num_steps, replace = TRUE)
cumulative_sum <- cumsum(steps)
data <- data.frame(Step = 1:num_steps, Position = cumulative_sum)
# 繪製隨機漫步的圖
ggplot(data, aes(x = Step, y = Position)) +
geom_line() +
labs(title = "隨機漫步",
x = "步數",
y = "位置")
install.packages("ggplot2")
# 假設有一個資料框 income_data 包含百分位數和對應的收入比例
income_data <- data.frame(percentile = c(0, 20, 100),
income_ratio = c(0, 10, 100))
# 計算 Lorenz curve 的資料點
income_data$Lorenz <- cumsum(income_data$income_ratio) / sum(income_data$income_ratio) * 100
# 使用 ggplot2 繪製 Lorenz curve
library(ggplot2)
ggplot(income_data, aes(x = percentile, y = Lorenz)) +
geom_line() +
geom_point() +
labs(x = "Percentage of households",
y = "Percentage of total income",
title = "Lorenz Curve: The bottom 20% of all households have 10% of the total income")
