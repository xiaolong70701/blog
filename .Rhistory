edges <- matrix(c(1, 1, 1, 2, 2, 3, 1, 3, 2, 4, 3, 4), ncol = 2, byrow = TRUE)
G <- graph(edges, n = length(vertices), directed = FALSE)
V(G)$name <- vertices
plot(G, vertex.label = V(G)$name)
